{
  "$id": "https://derive.build/schemas/toon-ir-v0.1.json",
  "title": "Derive TOON IR v0.1",
  "description": "Schema for Derive Agent IR in TOON format (Layer 2). Preview.",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "module_id": {
      "type": "string",
      "minLength": 1
    },
    "module_path": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "enum": [
        "typescript",
        "javascript",
        "python"
      ]
    },
    "extracted_at": {
      "type": "string",
      "minLength": 1
    },
    "token_count": {
      "type": "integer",
      "minimum": 0
    },
    "entry_points": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "const": "entry_point"
          },
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "signature": {
            "type": "string"
          },
          "confidence": {
            "type": "string",
            "enum": [
              "confirmed",
              "inferred",
              "uncertain"
            ]
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "kind",
          "id",
          "name",
          "signature",
          "confidence"
        ],
        "additionalProperties": false
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "const": "constraint"
          },
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": [
              "security",
              "api_contract",
              "data_schema",
              "behavioral",
              "compliance"
            ]
          },
          "confidence": {
            "type": "string",
            "enum": [
              "confirmed",
              "inferred",
              "uncertain"
            ]
          },
          "rejected_alternatives": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "description": {
                  "type": "string"
                },
                "reason": {
                  "type": "string"
                }
              },
              "required": [
                "description",
                "reason"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "kind",
          "id",
          "description",
          "category",
          "confidence"
        ],
        "additionalProperties": false
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "const": "dependency"
          },
          "id": {
            "type": "string",
            "minLength": 1
          },
          "module": {
            "type": "string",
            "minLength": 1
          },
          "dep_type": {
            "type": "string",
            "enum": [
              "internal",
              "external"
            ]
          },
          "confidence": {
            "type": "string",
            "enum": [
              "confirmed",
              "inferred",
              "uncertain"
            ]
          }
        },
        "required": [
          "kind",
          "id",
          "module",
          "dep_type",
          "confidence"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "schema_version",
    "module_id",
    "module_path",
    "language",
    "extracted_at",
    "entry_points",
    "constraints",
    "dependencies"
  ],
  "additionalProperties": false
}
